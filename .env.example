# Copy this file to .env and fill in your values

# MySQL connection string
# Local:   mysql://root:password@localhost:3306/grocsto_db
# Railway: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/grocsto_db"

# Public URL of your app (used for QR code generation)
# Set to your Railway domain after deploy, e.g. https://grocsto.up.railway.app
APP_URL="http://localhost:5000"

# Razorpay — https://dashboard.razorpay.com (optional, COD works without this)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Cloudinary — https://cloudinary.com/console (required for product images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
